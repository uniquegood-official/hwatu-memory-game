{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "hwatu-app",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "const h=require('http'),f=require('fs'),p=require('path');const mime={'.html':'text/html','.css':'text/css','.js':'application/javascript','.json':'application/json','.png':'image/png','.jpg':'image/jpeg'};h.createServer((q,r)=>{let u=q.url==='/'?'/index.html':decodeURIComponent(q.url);let fp=p.join(process.cwd(),u);f.readFile(fp,(e,d)=>{if(e){r.writeHead(404);r.end('Not found');return}let ext=p.extname(fp);r.writeHead(200,{'Content-Type':mime[ext]||'text/plain; charset=utf-8'});r.end(d)})}).listen(3000,()=>console.log('Server running on port 3000'))"],
      "port": 3000
    }
  ]
}
